# Gateway
GATEWAY_PORT=8000
GATEWAY_HOST=0.0.0.0
API_KEY=your_api_key_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Workers (comma-separated list of Ollama worker URLs)
WORKER_URLS=http://worker1:11434,http://worker2:11434

# Model
DEFAULT_MODEL=llama3.1:8b
MAX_TOKENS=2048
REQUEST_TIMEOUT=120

# Routing Strategy: round_robin | least_latency | queue_depth
ROUTING_STRATEGY=least_latency

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=30

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
